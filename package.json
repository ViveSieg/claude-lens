{
  "name": "claude-iris",
  "version": "0.3.7",
  "publishConfig": {
    "access": "public"
  },
  "description": "Render Claude Code's terminal replies in a browser tab — markdown, KaTeX, Mermaid, syntax highlighting. Optional NotebookLM tutor wizard with role templates.",
  "bin": {
    "claude-iris": "bin/claude-iris-cli.js"
  },
  "files": [
    "bin/*.js",
    "bin/claude-iris",
    "bin/listen.py",
    "commands/",
    "hooks/*.py",
    "roles/",
    "server/main.py",
    "server/requirements.txt",
    "server/static/",
    "install.sh",
    "LICENSE",
    "README.md",
    "README.zh.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node bin/postinstall.js"
  },
  "os": ["darwin", "linux"],
  "keywords": [
    "claude",
    "claude-code",
    "notebooklm",
    "markdown",
    "katex",
    "mermaid",
    "render",
    "mirror"
  ],
  "author": "ViveSieg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ViveSieg/claude-iris.git"
  },
  "homepage": "https://github.com/ViveSieg/claude-iris",
  "bugs": {
    "url": "https://github.com/ViveSieg/claude-iris/issues"
  }
}
